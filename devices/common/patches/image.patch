--- a/scripts/gen_image_generic.sh
+++ b/scripts/gen_image_generic.sh
@@ -5,6 +5,22 @@
     echo "SYNTAX: $0 <file> <kernel size> <kernel directory> <rootfs size> <rootfs image> [<align>]"
     exit 1
 fi
+# --------------------------------------------------------------------
+# MeowWrt 命名规则：强制修改输出文件名
+# 示例：
+#   openwrt-x86-64-generic-ext4-combined-efi.img
+#   → MeowWrt-10.05.2025-x86-64-generic-ext4-combined-efi.img
+# --------------------------------------------------------------------
+DATE=$(date +%m.%d.%Y)
+ORIGINAL_OUTPUT="$1"
+BASENAME=$(basename "$ORIGINAL_OUTPUT")
+DIRNAME=$(dirname "$ORIGINAL_OUTPUT")
+STRIPPED=$(echo "$BASENAME" | sed 's/^openwrt-//')
+NEW_BASENAME="MeowWrt-${DATE}-${STRIPPED}"
+OUTPUT="${DIRNAME}/${NEW_BASENAME}"
+shift
+set -- "$OUTPUT" "$@"
+echo "⚡ MeowWrt: 输出文件名已强制改为 $OUTPUT"
 
 OUTPUT="$1"
 KERNELSIZE="$2"
